{
  "name": "3D Matching DevContainer",
  "dockerComposeFile": ["./docker-compose.yaml"],
  "service": "app-dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "mounts": [
    {
      "type": "volume",
      "target": "${containerWorkspaceFolder}/.venv"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "astral-sh.ty"
      ]
    }
  },
  "postAttachCommand": "sudo chown -R vscode:vscode /workspace && uv sync --all-packages"
}